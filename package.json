{
  "name": "multi-project-gateway",
  "version": "0.6.0",
  "type": "module",
  "description": "Route Discord messages to per-project Claude Code CLI sessions",
  "bin": {
    "mpg": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "start": "node dist/cli.js start",
    "dev": "tsx src/cli.ts start",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "discord.js": "^14.14.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.5.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "claude",
    "claude-code",
    "discord",
    "gateway",
    "multi-project"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yama-kei/multi-project-gateway.git"
  },
  "license": "MIT"
}
